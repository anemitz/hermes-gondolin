# Gondolin host-secret configuration. Keep file mode 0600.
#
# Each secret needs two lines:
#   SECRET_<name>=<api-key>
#   HOSTS_<name>=<comma-separated hostnames the key may be sent to>
#
# The <name> must match between SECRET_ and HOSTS_ lines.
# The secret will be passed as --host-secret to gondolin for each listed host.
#
# Any line without a SECRET_ or HOSTS_ prefix is passed as a plain --env var.

# --- OpenRouter ---
# SECRET_OPENROUTER=sk-or-...
# HOSTS_OPENROUTER=openrouter.ai

# --- OpenAI ---
# SECRET_OPENAI=sk-...
# HOSTS_OPENAI=api.openai.com

# --- Anthropic ---
# SECRET_ANTHROPIC=sk-ant-...
# HOSTS_ANTHROPIC=api.anthropic.com

# --- Additional allowed hosts (no secret needed) ---
# Hosts from HOSTS_* entries are automatically allowed.
# Use ALLOW_HOSTS for extra hosts the agent should reach without a secret.
# ALLOW_HOSTS=* 
# ALLOW_HOSTS=duckduckgo.com,*.duckduckgo.com,github.com,*.github.com,pypi.org,api.firecrawl.dev

# --- Execution settings ---
# Skip dangerous command approval prompts (gondolin is the security boundary)
# AUTO_APPROVE=true

# --- Plain env vars (not secrets, passed as --env) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4
